# Copy this file to ".env" and fill in your values. ".env" is git-ignored —
# your secrets never get committed. (On Render, set these as Environment vars
# in the dashboard instead of using a file.)

# ---- Data source for the Scalper's Cockpit -------------------------------
# "nse"   (default) = free NSE option chain, ~3-min OI, local network only
# "angel"           = Angel One SmartAPI, seconds-fresh OI, works on the cloud
OI_SOURCE=angel

# ---- Angel One SmartAPI credentials (only needed when OI_SOURCE=angel) ----
# 1. Create a SmartAPI app at https://smartapi.angelone.in  -> API key
# 2. Enable TOTP at https://smartapi.angelone.in/enable-totp -> secret (base32)
# 3. Your Angel login id (client code) and MPIN
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_MPIN=
ANGEL_TOTP_SECRET=

# ---- Optional: AI morning briefing ---------------------------------------
# ANTHROPIC_API_KEY=
# GLOBAL_AI_MODEL=claude-haiku-4-5
